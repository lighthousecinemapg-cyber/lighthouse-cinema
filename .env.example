# ================================================================
# LIGHTHOUSE CINEMA BOOKING SYSTEM â ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ================================================================

# SQUARE API (get from https://developer.squareup.com/apps)
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox
# Change to 'production' when going live

# GOOGLE CALENDAR API (get from Google Cloud Console)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=lighthousecinemapg@gmail.com

# EMAIL (for sending confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lighthousecinemapg@gmail.com
SMTP_PASS=your_app_password

# SITE
NEXT_PUBLIC_SITE_URL=https://lighthousecinemapg.com
NEXT_PUBLIC_CINEMA_NAME=Lighthouse Cinema
NEXT_PUBLIC_CINEMA_PHONE=(831) 717-3124

# TAX & FEES
NEXT_PUBLIC_SALES_TAX_RATE=0.0925
NEXT_PUBLIC_SERVICE_FEE_RATE=0.18
NEXT_PUBLIC_DEPOSIT_RATE=0.20

# ================================================================
# GOOGLE BUSINESS PROFILE API (CineMax AI Automation)
# ================================================================

# GBP OAuth 2.0 (get from Google Cloud Console > APIs > Business Profile)
GBP_ACCOUNT_ID=your_gbp_account_id
GBP_LOCATION_ID=your_gbp_location_id
GBP_ACCESS_TOKEN=your_gbp_oauth_access_token

# AI MODEL (for review responses & post generation)
# Supported: openai, gemini, claude
AI_PROVIDER=openai
AI_API_KEY=your_ai_api_key
AI_MODEL=gpt-4o
# For Gemini: AI_PROVIDER=gemini, AI_MODEL=gemini-1.5-pro
# For Claude: AI_PROVIDER=claude, AI_MODEL=claude-sonnet-4-20250514

# CRON SECURITY (prevents unauthorized cron triggers)
CRON_SECRET=your_random_cron_secret_string

# MANAGER EMAIL (for weekly reports & escalations)
MANAGER_EMAIL=lighthousecinemapg@gmail.com

# SQUARE WEB PAYMENTS (frontend)
NEXT_PUBLIC_SQUARE_APP_ID=your_square_app_id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your_square_location_id

# GOOGLE OAUTH 2.0 (for auto-refreshing GBP + Calendar tokens)
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
# After first deploy, visit /api/auth/google/start to get the refresh_token
GOOGLE_OAUTH_REDIRECT_URI=https://lighthousecinemapg.com/api/auth/google/callback

# TWILIO (optional â for SMS alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OWNER_PHONE=+18317173124
